{
  "root": true,
  "env": {
    "node": true,
    "browser": true,
    "jest": true,
    "es2022": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "ignorePatterns": [
    "node_modules/",
    "server/coverage/",
    "server/logs/",
    "server/data/"
  ],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off"
  }
}
